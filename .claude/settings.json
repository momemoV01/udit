{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(udit status:*)",
      "Bash(udit list:*)",
      "Bash(udit console:*)",
      "Bash(udit editor refresh:*)",
      "Bash(udit test:*)",
      "Bash(udit profiler:*)",
      "Bash(udit version:*)",
      "Bash(udit --help:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git add:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(go build:*)",
      "Bash(go vet:*)",
      "Bash(go test:*)",
      "Bash(go fmt:*)",
      "Bash(gofmt:*)",
      "Bash(gh repo view:*)",
      "Bash(gh issue list:*)",
      "Bash(gh pr list:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(gh release view:*)",
      "Bash(gh run watch:*)",
      "Bash(git commit:*)",
      "Bash(git tag:*)"
    ],
    "ask": [
      "Bash(udit editor play:*)",
      "Bash(udit editor stop:*)",
      "Bash(udit exec:*)",
      "Bash(udit reserialize:*)",
      "Bash(udit menu:*)",
      "Bash(git push:*)",
      "Bash(git pull:*)",
      "Bash(git merge:*)",
      "Bash(git rebase:*)",
      "Bash(gh repo create:*)",
      "Bash(gh pr create:*)",
      "Bash(gh issue create:*)",
      "Bash(gh release create:*)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git branch -D:*)",
      "Bash(git clean -fd:*)",
      "Bash(rm -rf:*)",
      "Bash(gh repo delete:*)",
      "Bash(gh release delete:*)"
    ]
  }
}
